<Window x:Class="CybersecBot_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Assistant"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="CYBERSECURITY AWARENESS ASSISTANT"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="Cyan"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Main Tabs -->
        <TabControl Grid.Row="1">

            <!-- CHATBOT -->
            <TabItem Header="💬 Chatbot">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <RichTextBox x:Name="rtbChat"
                                 IsReadOnly="True"
                                 Background="Black"
                                 Foreground="Lime"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBox x:Name="txtUserInput"
                                 Width="700"
                                 Height="35"
                                 FontSize="15"/>

                        <Button x:Name="btnSend"
                                Content="Send"
                                Width="120"
                                Height="35"
                                Margin="10,0,0,0"
                                Click="btnSend_Click"/>
                    </StackPanel>

                </Grid>
            </TabItem>

            <!-- TASK ASSISTANT -->
            <TabItem Header="📋 Task Assistant">

                <ScrollViewer>
                    <StackPanel Margin="20">

                        <TextBlock Text="Task Title" FontWeight="Bold"/>
                        <TextBox x:Name="txtTaskTitle"
                                 Height="35"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Description" FontWeight="Bold"/>
                        <TextBox x:Name="txtTaskDescription"
                                 Height="70"
                                 AcceptsReturn="True"
                                 Margin="0,5,0,15"/>

                        <TextBlock Text="Reminder Date" FontWeight="Bold"/>
                        <DatePicker x:Name="dpReminder"
                                    Margin="0,5,0,15"/>

                        <TextBlock Text="Task Number to Complete" FontWeight="Bold"/>
                        <TextBox x:Name="txtTaskNumber"
                                 Height="35"
                                 Margin="0,5,0,20"/>

                        <Button x:Name="btnExit"
                                Content="Exit"
                                Width="120"
                                Height="35"
                                Margin="5"
                                Click="btnExit_Click"/>

                        <WrapPanel>

                            <Button x:Name="btnAddTask"
                                    Content="Add Task"
                                    Width="120"
                                    Height="35"
                                    Margin="5"
                                    Click="btnAddTask_Click"/>

                            <Button x:Name="btnViewTasks"
                                    Content="View Tasks"
                                    Width="120"
                                    Height="35"
                                    Margin="5"
                                    Click="btnViewTasks_Click"/>

                            <Button x:Name="btnCompleteTask"
                                    Content="Complete Task"
                                    Width="140"
                                    Height="35"
                                    Margin="5"
                                    Click="btnCompleteTask_Click"/>

                            <ListBox x:Name="lstTasks"
         Height="220"
         Margin="0,20,0,0"/>

                        </WrapPanel>
                        

                    </StackPanel>
                </ScrollViewer>

            </TabItem>

            <!-- QUIZ -->
            <TabItem Header="❓ Cybersecurity Quiz">

                <StackPanel Margin="20">

                    <TextBlock Text="Cybersecurity Quiz"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <TextBlock x:Name="txtQuestion"
                               FontSize="18"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <ComboBox x:Name="cmbAnswers"
                              Height="35"
                              Margin="0,0,0,20"/>

                    <Button x:Name="btnSubmitQuiz"
                            Content="Submit Answer"
                            Width="180"
                            Height="40"
                            Click="btnSubmitQuiz_Click"/>

                    <TextBlock x:Name="txtScore"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,20,0,0"/>

                </StackPanel>

            </TabItem>

            <!-- ACTIVITY LOG -->
            <TabItem Header="📜 Activity Log">

                <Grid Margin="15">
                    <ListBox x:Name="lstActivityLog"/>
                </Grid>

            </TabItem>

        </TabControl>

    </Grid>

</Window>